{
  "experiment_name": "oneformer_synthetic_smoke",
  "seed": 42,
  "device_target": "Ascend",
  "mode": "GRAPH",
  "dataset": {
    "name": "synthetic",
    "root": "",
    "num_classes": 3,
    "image_size": 128,
    "batch_size": 2,
    "num_workers": 1,
    "train_length": 8,
    "val_length": 4
  },
  "model": {
    "name": "oneformer_tiny",
    "image_size": 128,
    "embed_dims": [16, 32, 64, 128],
    "depths": [1, 1, 1, 1],
    "num_heads": [1, 1, 2, 4],
    "sr_ratios": [4, 2, 1, 1],
    "mlp_ratio": 2.0,
    "drop_rate": 0.0,
    "decoder_dim": 64,
    "mask_dim": 64,
    "query_dim": 64,
    "num_queries": 20,
    "query_heads": 4,
    "query_layers": 2
  },
  "train": {
    "epochs": 1,
    "learning_rate": 0.0001,
    "weight_decay": 0.01,
    "print_every": 1,
    "eval_every": 1,
    "save_best": true,
    "output_dir": "outputs/oneformer_synthetic_smoke"
  }
}
