{
  "experiment_name": "setr_tiny_ade20k_fast",
  "seed": 42,
  "device_target": "Ascend",
  "mode": "GRAPH",
  "dataset": {
    "name": "ade20k",
    "root": "data/ade20k",
    "num_classes": 150,
    "image_size": 256,
    "batch_size": 4,
    "num_workers": 4,
    "max_train_samples": 4000,
    "max_val_samples": 1000,
    "random_subset": true
  },
  "model": {
    "name": "setr_tiny",
    "image_size": 256,
    "patch_size": 16,
    "embed_dim": 128,
    "depth": 4,
    "num_heads": 4,
    "mlp_ratio": 3.0,
    "drop_rate": 0.0,
    "decoder_dim": 64
  },
  "train": {
    "epochs": 40,
    "learning_rate": 0.0002,
    "lr_schedule": "cosine",
    "min_learning_rate": 0.00002,
    "warmup_epochs": 1,
    "warmup_start_lr": 0.00004,
    "weight_decay": 0.01,
    "print_every": 20,
    "eval_every": 5,
    "save_best": true,
    "output_dir": "outputs/setr_tiny_ade20k_fast"
  }
}
