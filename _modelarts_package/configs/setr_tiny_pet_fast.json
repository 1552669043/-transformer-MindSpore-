{
  "experiment_name": "setr_tiny_pet_fast",
  "seed": 42,
  "device_target": "Ascend",
  "mode": "GRAPH",
  "dataset": {
    "name": "pet",
    "root": "data/pet",
    "num_classes": 3,
    "class_mode": "trimap",
    "image_size": 256,
    "batch_size": 4,
    "num_workers": 4,
    "max_train_samples": null,
    "max_val_samples": null,
    "random_subset": false
  },
  "model": {
    "name": "setr_tiny",
    "image_size": 256,
    "patch_size": 16,
    "embed_dim": 128,
    "depth": 4,
    "num_heads": 4,
    "mlp_ratio": 2.0,
    "drop_rate": 0.0,
    "decoder_dim": 64
  },
  "train": {
    "epochs": 40,
    "learning_rate": 0.00012,
    "lr_schedule": "cosine",
    "min_learning_rate": 0.000012,
    "warmup_epochs": 1,
    "warmup_start_lr": 0.000024,
    "weight_decay": 0.01,
    "print_every": 20,
    "eval_every": 5,
    "save_best": true,
    "output_dir": "outputs/setr_tiny_pet_fast"
  }
}
