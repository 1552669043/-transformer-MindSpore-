{
  "experiment_name": "mask2former_tiny_pet_fast",
  "seed": 42,
  "device_target": "Ascend",
  "mode": "GRAPH",
  "dataset": {
    "name": "pet",
    "root": "data/pet",
    "num_classes": 3,
    "class_mode": "trimap",
    "image_size": 256,
    "batch_size": 4,
    "num_workers": 4,
    "max_train_samples": null,
    "max_val_samples": null,
    "random_subset": false
  },
  "model": {
    "name": "mask2former_tiny",
    "image_size": 256,
    "embed_dims": [16, 32, 64, 128],
    "depths": [1, 1, 1, 1],
    "num_heads": [1, 1, 2, 4],
    "sr_ratios": [4, 2, 1, 1],
    "mlp_ratio": 2.0,
    "drop_rate": 0.0,
    "decoder_dim": 64,
    "mask_dim": 64,
    "query_dim": 64,
    "num_queries": 20,
    "query_heads": 4,
    "query_layers": 2
  },
  "train": {
    "epochs": 40,
    "learning_rate": 0.00012,
    "lr_schedule": "cosine",
    "min_learning_rate": 0.000012,
    "warmup_epochs": 1,
    "warmup_start_lr": 0.000024,
    "weight_decay": 0.01,
    "print_every": 20,
    "eval_every": 5,
    "save_best": true,
    "output_dir": "outputs/mask2former_tiny_pet_fast"
  }
}
