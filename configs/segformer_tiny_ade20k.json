{
  "experiment_name": "segformer_tiny_ade20k",
  "seed": 42,
  "device_target": "Ascend",
  "mode": "GRAPH",
  "dataset": {
    "name": "ade20k",
    "root": "data/ade20k",
    "num_classes": 150,
    "image_size": 512,
    "batch_size": 4,
    "num_workers": 4,
    "max_train_samples": null,
    "max_val_samples": null
  },
  "model": {
    "name": "segformer_tiny",
    "image_size": 512,
    "embed_dims": [32, 64, 160, 256],
    "depths": [2, 2, 2, 2],
    "num_heads": [1, 2, 5, 8],
